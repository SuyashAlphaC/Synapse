node_modules/
# Move build artifacts
move/**/build/
move/**/.coverage_map.mvcov
move/**/.trace

# Node / TypeScript
node_modules/
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# Env files (CRITICAL — never commit)
.env
.env.local
.env.*.local
.envrc

# Key material (CRITICAL — never commit). The dashboard downloads vault
# session/delegate keys as .key files; keep them out of git permanently.
*.key
*.key.json
*-session-*.key
secrets/*
# …but allow the docs that explain how to use the directory.
!secrets/README.md
!secrets/.gitkeep

# Sui local config
.sui/
sui_config/

# Walrus local config
.walrus/

# Editor
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.DS_Store
*.swp

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/
.nyc_output/

# Local agent runtime data (never check in)
runtime/
!sdk/packages/vault/src/runtime/
!sdk/packages/vault/src/runtime/**
agent-data/
*.delegate-key

# Synapse — local session keys for live-tick vaults
scripts/live-vaults.json

# local demo helper (hardcoded key path)
run-cross-read.sh
# sui publish artifact
move/**/Published.toml

# local pitch deck (not part of the repo)
pitch/

# AWS CDK synth output (generated locally on deploy)
infrastructure/aws/cdk.out/

# local messaging-demo helper (holds owner key)
run-messaging.sh
