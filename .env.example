# Synapse Vault — headless runtime environment template.
#
# Copy to `.env` and fill in the values for one vault. Each vault gets
# its own `.env` + own runtime; only the SYNAPSE_SESSION_KEY (and
# optional MEMWAL_DELEGATE_KEY) differ between vaults. Everything else
# is shared across all vaults on the same Synapse package.
#
# DO NOT COMMIT `.env` — it is gitignored. Use Docker / Fly / Railway
# secrets in production; this file is for local dev only.

# -- Required: on-chain identity ---------------------------------------------
SYNAPSE_PACKAGE_ID=0x5da36d892956a4659415e245126a3964dd5aa6cf19ec2fdf6332bf828a4c58ed
SYNAPSE_AGENT_ID=0x<your-vault-agent-id>

# -- Required: session key (PICK ONE source) ---------------------------------
# A. Inline (env-injected; matches AWS Fargate from Secrets Manager).
#    For local dev: `SYNAPSE_SESSION_KEY=$(jq -r .secretBase64 ~/.synapse/vault.key)`
# SYNAPSE_SESSION_KEY=

# B. Path to the dashboard's `.key` JSON file on disk.
SYNAPSE_SESSION_KEY_PATH=/run/secrets/session-key

# C. Or pass `--secrets-dir /run/secrets` and mount these files:
#      /run/secrets/session-key       (suiprivkey…, base64 32 B, or .key JSON)
#      /run/secrets/memwal-delegate   (64-char hex, optional)

# -- Optional: MemWal memory recall ------------------------------------------
# MEMWAL_DELEGATE_KEY=<64-char hex>
# MEMWAL_RELAYER_URL=https://relayer.staging.memwal.ai  # default for testnet

# -- Optional: package upgrade history (for vaults minted on older versions) -
# SYNAPSE_PACKAGE_HISTORY=0x<v3>,0x<v2>,0x<v1>

# -- Network --------------------------------------------------------------
SYNAPSE_FULLNODE_URL=https://fullnode.testnet.sui.io:443
SYNAPSE_WALRUS_NETWORK=testnet

# -- Tick schedule ----------------------------------------------------------
SYNAPSE_TICK_INTERVAL_MS=600000        # 10 minutes
SYNAPSE_MAX_FAILURES=5                 # exit after N consecutive failures

# -- Operator alerting (optional) -------------------------------------------
# A Discord/Slack incoming webhook, or any URL that accepts a JSON POST.
# Fired on: runtime start, max-failures crash, top-level crash.
# SYNAPSE_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# -- Marketplace strategy hardening (optional but recommended in prod) ------
# Comma-separated lowercase 64-char hex code_hashes that the runtime is
# allowed to load from Walrus. Any Walrus-fetched strategy whose
# code_hash isn't in the list is refused; the runtime falls back to the
# built-in default. Empty / unset means "allow everything the on-chain
# consent flag allows" (the legacy default).
# SYNAPSE_ALLOWED_STRATEGY_HASHES=
# Comma-separated 0x-prefixed Sui addresses of trusted strategy publishers.
# Same semantics: hard gate on top of on-chain consent.
# SYNAPSE_ALLOWED_STRATEGY_PUBLISHERS=
# Set to 0/false/no/off to globally refuse Walrus-loaded strategies even
# when a vault opted in on-chain.
# SYNAPSE_ALLOW_WALRUS_STRATEGIES=true

# -- Logging --------------------------------------------------------------
# Pino level: trace | debug | info | warn | error
SYNAPSE_LOG_LEVEL=info

# -- Market / pool (MAINNET-CRITICAL) ---------------------------------------
# DeepBook pool + quote asset the vault trades against. The defaults target a
# testnet SUI/DBUSDC pool; a MAINNET operator MUST set these or the runtime
# will silently trade against the testnet pool config.
# SYNAPSE_POOL_ID=0x<deepbook-pool-id>
# SYNAPSE_DEEPBOOK_POOL_ID=0x<deepbook-pool-id>   # alias accepted
# SYNAPSE_QUOTE_TYPE=0x<pkg>::usdc::USDC

# -- Strategy tuning (optional; sensible defaults baked in) -----------------
# SYNAPSE_TARGET_BASE_WEIGHT=0.5         # target base-asset fraction (0..1)
# SYNAPSE_DRIFT_THRESHOLD=0.05           # rebalance when |drift| exceeds this
# SYNAPSE_SLIPPAGE_TOLERANCE=0.005       # min-amount-out guard (0.5%)
# SYNAPSE_STRATEGY_REGISTRY_JSON={"<strategyId>":"<slug>"}  # slug overrides
# SYNAPSE_WALRUS_EPOCHS=1                # storage epochs for report blobs

# -- Auto-refuel (optional) -------------------------------------------------
# Top up the session address from the treasury when it runs low.
# SYNAPSE_REFUEL_THRESHOLD_MIST=200000000
# SYNAPSE_REFUEL_AMOUNT_MIST=500000000
# WAL refuel (Walrus storage token), if the runtime acquires WAL on-chain:
# SYNAPSE_WAL_REFUEL_THRESHOLD=...
# SYNAPSE_WAL_REFUEL_AMOUNT=...
# SYNAPSE_WAL_EXCHANGE_PKG=0x...
# SYNAPSE_WAL_EXCHANGE_IDS=0x...,0x...

# -- Seal artifact encryption (optional) ------------------------------------
# Encrypt audit-report blobs before Walrus upload; decryptable only by the
# vault's session/owner key via synapse_seal::policy::seal_approve.
# SYNAPSE_SEAL_PACKAGE_ID=0x<synapse_seal-package>
# SYNAPSE_SEAL_KEY_SERVERS=0x<server-1>,0x<server-2>   # override defaults
