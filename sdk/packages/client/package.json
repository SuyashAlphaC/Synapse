{
  "name": "@synapse-core/client",
  "version": "0.1.0",
  "description": "Synapse Core TypeScript client — Sui + Walrus + MemWal + Seal + Sui Stack Messaging",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "default": "./dist/agent.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "default": "./dist/wallet.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts.d.ts",
      "default": "./dist/artifacts.js"
    },
    "./zklogin": {
      "types": "./dist/zklogin.d.ts",
      "default": "./dist/zklogin.js"
    },
    "./seal": {
      "types": "./dist/seal.d.ts",
      "default": "./dist/seal.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.2",
    "@mysten/walrus": "^1.1.7",
    "@mysten/seal": "^1.1.3",
    "@mysten/bcs": "^2.0.5",
    "@noble/hashes": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.10.0"
  }
}
