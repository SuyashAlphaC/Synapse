{
  "name": "@synapse-core/indexer",
  "version": "0.1.0",
  "description": "Synapse Core indexer — polls synapse_core Sui events into per-vault GraphQL views (in-memory v1)",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "@synapse-core/client": "*",
    "@mysten/sui": "^2.16.2",
    "graphql": "^16.10.0",
    "graphql-yoga": "^5.10.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
