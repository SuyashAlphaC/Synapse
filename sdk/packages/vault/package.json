{
  "name": "@synapse-core/vault",
  "version": "0.1.0",
  "description": "Synapse Vault — autonomous AI treasury manager. Strategy engine, rebalance executor, audit-report generator. Built on Synapse Core.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./strategies": {
      "types": "./dist/strategies/index.d.ts",
      "default": "./dist/strategies/index.js"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "default": "./dist/executor.js"
    },
    "./report": {
      "types": "./dist/report.d.ts",
      "default": "./dist/report.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runtime-core": {
      "types": "./dist/runtime/runtime.d.ts",
      "default": "./dist/runtime/runtime.js"
    },
    "./keypair": {
      "types": "./dist/runtime/keypair.d.ts",
      "default": "./dist/runtime/keypair.js"
    },
    "./langgraph": {
      "types": "./dist/runtime/langgraph-strategy.d.ts",
      "default": "./dist/runtime/langgraph-strategy.js"
    },
    "./strategy-bundle": {
      "types": "./dist/runtime/strategy-bundle.d.ts",
      "default": "./dist/runtime/strategy-bundle.js"
    }
  },
  "bin": {
    "synapse-vault-runtime": "./dist/runtime/bin/run.js",
    "synapse-cross-agent-read": "./dist/runtime/bin/cross-agent-read.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@langchain/langgraph": "^1.3.0",
    "@mysten/deepbook-v3": "^1.3.6",
    "@mysten/sui": "^2.16.2",
    "@mysten/walrus": "^1.1.7",
    "@noble/hashes": "^2.0.0",
    "@pythnetwork/price-service-client": "^1.11.0",
    "@synapse-core/adapter-langgraph": "*",
    "@synapse-core/client": "*",
    "@synapse-core/memwal-bridge": "*",
    "pino": "^10.3.1",
    "esbuild": "^0.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "msw": "^2.14.6",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
